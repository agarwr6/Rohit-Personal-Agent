# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-key-here

# Resend API key for notify_rohit tool — get one at https://resend.com
RESEND_API_KEY=your-resend-key-here

# Email address that should receive recruiter-interest notifications
ROHIT_NOTIFY_EMAIL=you@example.com

# Upstash Redis for rate limiting — create a DB at https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Langfuse observability — sign up at https://cloud.langfuse.com
# NOTE: the SDK reads LANGFUSE_BASEURL (no underscore), not LANGFUSE_BASE_URL.
# Use the US host if your project is in the US data region.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASEURL=https://us.cloud.langfuse.com
